<mxfile host="app.diagrams.net">
  <diagram name="Class Diagram">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- USER CLASS -->
        <mxCell id="user" value="User&#xa;---------------------&#xa;+ name: String&#xa;+ email: String&#xa;+ password: String&#xa;+ isAccountVerified: Boolean&#xa;+ address: Object&#xa;+ listedHomes: ObjectId[]&#xa;+ bookedHomes: ObjectId[]&#xa;+ favoriteHomes: ObjectId[]" 
        style="shape=rectangle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="260" height="200" as="geometry"/>
        </mxCell>

        <!-- HOME CLASS -->
        <mxCell id="home" value="Home&#xa;---------------------&#xa;+ title: String&#xa;+ description: String&#xa;+ pricePerNight: Number&#xa;+ address: Object&#xa;+ maxGuests: Number&#xa;+ bedrooms: Number&#xa;+ bathrooms: Number&#xa;+ isAvailable: Boolean&#xa;+ owner: ObjectId" 
        style="shape=rectangle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="700" y="100" width="260" height="220" as="geometry"/>
        </mxCell>

        <!-- BOOKING CLASS -->
        <mxCell id="booking" value="Booking&#xa;---------------------&#xa;+ user: ObjectId&#xa;+ home: ObjectId&#xa;+ owner: ObjectId&#xa;+ checkInDate: Date&#xa;+ checkOutDate: Date&#xa;+ totalDays: Number&#xa;+ totalPrice: Number&#xa;+ status: String&#xa;+ paymentStatus: String" 
        style="shape=rectangle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="400" y="400" width="280" height="220" as="geometry"/>
        </mxCell>

        <!-- RELATIONSHIPS -->

        <!-- User -> Home -->
        <mxCell edge="1" source="user" target="home" parent="1" value="owns (1:N)">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- User -> Booking -->
        <mxCell edge="1" source="user" target="booking" parent="1" value="creates (1:N)">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Home -> Booking -->
        <mxCell edge="1" source="home" target="booking" parent="1" value="booked in (1:N)">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Owner relation -->
        <mxCell edge="1" source="user" target="booking" parent="1" value="owner reference">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>