<mxfile host="app.diagrams.net">
  <diagram name="Flowchart">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Decision: Login -->
        <mxCell id="d1" value="User Logged In?" style="rhombus;" vertex="1" parent="1">
          <mxGeometry x="370" y="100" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Register/Login -->
        <mxCell id="login" value="Register / Login" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="150" y="220" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- View Homes -->
        <mxCell id="view" value="View Available Homes" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="400" y="220" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Select Home -->
        <mxCell id="select" value="Select Home" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Booking -->
        <mxCell id="book" value="Enter Booking Details" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="400" y="420" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Confirm -->
        <mxCell id="confirm" value="Booking Stored in DB" style="rectangle;" vertex="1" parent="1">
          <mxGeometry x="400" y="520" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="End" style="ellipse;" vertex="1" parent="1">
          <mxGeometry x="420" y="620" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Connections -->

        <mxCell edge="1" source="start" target="d1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="d1" target="login" parent="1" value="No">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="d1" target="view" parent="1" value="Yes">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="login" target="view" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="view" target="select" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="select" target="book" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="book" target="confirm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" source="confirm" target="end" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>