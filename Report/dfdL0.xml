<mxfile host="app.diagrams.net">
  <diagram name="DFD Level 0 Fixed">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Central Process -->
        <mxCell id="process" value="Room Rental System" style="ellipse;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="220" height="100" as="geometry"/>
        </mxCell>

        <!-- External Entity: User -->
        <mxCell id="user" value="User" style="shape=rectangle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- External Entity: Admin -->
        <mxCell id="admin" value="Admin" style="shape=rectangle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="700" y="160" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Data Flow: User to System -->
        <mxCell id="e1" value="Register / Login / Booking Request" edge="1" parent="1" source="user" target="process">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Data Flow: System to User -->
        <mxCell id="e2" value="Room Info / Booking Confirmation" edge="1" parent="1" source="process" target="user">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Data Flow: Admin to System -->
        <mxCell id="e3" value="Manage Rooms / Users" edge="1" parent="1" source="admin" target="process">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Data Flow: System to Admin -->
        <mxCell id="e4" value="Reports / Booking Details" edge="1" parent="1" source="process" target="admin">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>